{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Stellar Monopoly: API server",
      "cwd": "${workspaceFolder}/server",
      "program": "${workspaceFolder}/server/index.js",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Stellar Monopoly: API (watch)",
      "cwd": "${workspaceFolder}/server",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--watch", "index.js"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
