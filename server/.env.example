PORT=3847
STELLAR_NETWORK=testnet

# Public Stellar address that receives property purchases and taxes (fund it on testnet).
BANK_PUBLIC_KEY=

# Secret key of a funded account that pays Pass GO / Chance rewards to players (keep offline in production).
TREASURY_SECRET=

# Set to 1 to allow "Demo buy" without verifying a blockchain transaction (local testing only).
DEMO_SKIP_CHAIN=0

# Minimum native XLM (Horizon) to create a room or join as a new player. Default 800.
# Use 0 to allow any balance (still validates the public key). Reconnecting an existing seat is not re-checked.
# By default the balance gate is OFF. Set ENABLE_JOIN_BALANCE_CHECK=1 to enforce it.
# SKIP_JOIN_BALANCE_CHECK=1 skips the Horizon call entirely (local dev only).
MIN_JOIN_BALANCE_XLM=800
ENABLE_JOIN_BALANCE_CHECK=0
SKIP_JOIN_BALANCE_CHECK=1
