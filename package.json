{
  "name": "stellar-monopoly",
  "private": true,
  "version": "1.0.0",
  "description": "Stellar Monopoly — multiplayer Web3 board game",
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix server\" \"npm run dev --prefix client\"",
    "dev:client": "npm run dev --prefix client",
    "dev:server": "npm run dev --prefix server",
    "build": "npm run build --prefix client",
    "start": "npm run start --prefix server",
    "contracts:build": "cargo build --manifest-path contracts/sm-monopoly/Cargo.toml --target wasm32-unknown-unknown --release"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
